{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "types": [
      "nativewind/types",
      "react-native-css-interop/types"
    ],
    "strict": false,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    "babel.config.js"
  ]
}